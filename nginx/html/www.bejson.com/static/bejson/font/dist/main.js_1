import * as opentype from "/static/bejson/font/dist/opentype.module.min.js";

const form = document.forms.head;
form.oninput = renderText;

var cellCount = 100,
    cellWidth = 56,
    cellHeight = 50,
    cellMarginTop = 1,
    cellMarginBottom = 8,
    cellMarginLeftRight = 1,
    glyphMargin = 5,
    pixelRatio = window.devicePixelRatio || 1;

var pageSelected, font, fontScale, fontSize, fontBaseline, glyphScale, glyphSize, glyphBaseline;

var pageTotal = 5;
var fontData = {
    name: "font",
    fileName: "",
    glyphIndex: -1,
    drawPoints: false,
    drawArrows: false,
};

function enableHighDPICanvas(canvas) {
    if (typeof canvas === 'string') {
        canvas = document.getElementById(canvas);
    }
    var pixelRatio = window.devicePixelRatio || 1;
    if (pixelRatio === 1) return;
    var oldWidth = canvas.width;
    var oldHeight = canvas.height;
    canvas.width = oldWidth * pixelRatio;
    canvas.height = oldHeight * pixelRatio;
    canvas.style.width = oldWidth + 'px';
    canvas.style.height = oldHeight + 'px';
    canvas.getContext('2d').scale(pixelRatio, pixelRatio);
}

function showErrorMessage(message) {
    var el = document.getElementById('message');
    if (!message || message.trim().length === 0) {
        el.style.display = 'none';
    } else {
        el.style.display = 'block';
    }
    el.innerHTML = message;
}

function pathCommandToString(cmd) {
    var str = '<strong>' + cmd.type + '</strong> ' +
        ((cmd.x !== undefined) ? 'x=' + cmd.x + ' y=' + cmd.y + ' ' : '') +
        ((cmd.x1 !== undefined) ? 'x1=' + cmd.x1 + ' y1=' + cmd.y1 + ' ' : '') +
        ((cmd.x2 !== undefined) ? 'x2=' + cmd.x2 + ' y2=' + cmd.y2 : '');
    return str;
}

function contourToString(contour) {
    return '<pre class="contour">' + contour.map(function (point) {
        return '<span class="' + (point.onCurve ? 'on' : 'off') + 'curve">x=' + point.x + ' y=' + point.y + '</span>';
    }).join('\n') + '</pre>';
}

function formatUnicode(unicode) {
    unicode = unicode.toString(16);
    if (unicode.length > 4) {
        return ("000000" + unicode.toUpperCase()).substr(-6)
    } else {
        return ("0000" + unicode.toUpperCase()).substr(-4)
    }
}

function unicode2Char(unicodeStr, formatType = 0) {
    var s = String.fromCharCode(parseInt(unicodeStr, 16));

    // 1 路径，替换斜杠和冒号
    if (formatType == 1) {
        // CR LF 换行
        if (unicodeStr == "000D" || unicodeStr == "000A") {
            return "";
        }
        return s.replace("/", "")
            .replace("\\", "")
            .replace(":", "");
    }
    // 2 csv, 替换逗号和单个双引号
    else if (formatType == 2) {
        // CR LF 换行
        if (unicodeStr == "000D" || unicodeStr == "000A") {
            return "";
        }
        return s.replace(",", "")
            .replace('"', "");
    }
    else {
        return s;
    }
}

function displayGlyphData(glyphIndex) {
    if (glyphIndex < 0) {
        return;
    }

    const font = window.font;
    fontData.glyphIndex = glyphIndex;
    var glyph = font.glyphs.get(glyphIndex);

    var igSN = document.getElementById("glyph-sn"),
        igName = document.getElementById("input-name"),
        igChar = document.getElementById("input-char"),
        igXMin = document.getElementById("input-xmin"),
        igXMax = document.getElementById("input-xmax"),
        igYMin = document.getElementById("input-ymin"),
        igYMax = document.getElementById("input-ymax"),
        igWidth = document.getElementById("input-width"),
        igBearing = document.getElementById("input-bearing"),
        copyName = document.getElementById("copy-name"),
        copyChar = document.getElementById("copy-char");

    igSN.value = glyph.index + 1;
    igName.value = getValueDesc(glyph.name);
    copyName.disabled = igName.value == "" ? true : false;

    if (glyph.unicodes.length > 0) {
        var unicodeStr = glyph.unicodes.map(formatUnicode).join(', ');
        igChar.value = unicode2Char(unicodeStr);
        copyChar.disabled = false;
    } else {
        igChar.value = "";
        copyChar.disabled = true;
    }
    showUnicode();

    igXMin.value = getValueDesc(glyph.xMin);
    igXMax.value = getValueDesc(glyph.xMax);
    igYMin.value = getValueDesc(glyph.yMin);
    igYMax.value = getValueDesc(glyph.yMax);
    igWidth.value = getValueDesc(glyph.advanceWidth);
    igBearing.value = getValueDesc(glyph.leftSideBearing);

    var html = "";
    if (glyph.numberOfContours > 0) {
        var contours = glyph.getContours();
        html += '<span class="text-muted mx-2" style="margin-left:20px ">轮廓:</span><div id="glyph-contours">' + contours.map(contourToString).join('\n') + '</div>';
    } else if (glyph.isComposite) {
        html += '<span class="text-muted mx-2" style="margin-left:20px ">复合字形:</span><ul><li>' +
            glyph.components.map(function (component) {
                if (component.matchedPoints === undefined) {
                    return 'glyph ' + component.glyphIndex + ' at dx=' + component.dx + ', dy=' + component.dy;
                } else {
                    return 'glyph ' + component.glyphIndex + ' at matchedPoints=[' + component.matchedPoints + ']';
                }
            }).join('</li><li>') + '</li></ul>';
    } else if (glyph.path) {
        html += '<span class="text-muted mx-2" style="margin-left:20px ">路径:</span><pre>  ' + glyph.path.commands.map(pathCommandToString).join('\n  ') + '\n</pre>';
    }
    document.getElementById('path-data').innerHTML = html;
}

document.getElementById("unicode-format").addEventListener("change", showUnicode);
document.getElementById("unicode-case").addEventListener("change", showUnicode);

function showUnicode() {
    var valueEl = document.getElementById("input-unicode"),
        copyUnicode = document.getElementById("copy-unicode"),
        formatEl = document.getElementById("unicode-format"),
        caseEl = document.getElementById("unicode-case");

    var glyph = window.font.glyphs.get(fontData.glyphIndex);
    if (glyph.unicodes.length > 0) {
        var unicodeStr = glyph.unicodes.map(formatUnicode).join(', ');
        var formatType = formatEl.value;
        var caseType = caseEl.value;

        // 转小写
        if (caseType == "2") {
            unicodeStr = unicodeStr.toLowerCase();
        }

        // 格式化
        switch (formatType) {
            case "1": unicodeStr = unicodeStr; break; // 4E00
            case "2": unicodeStr = `U+${unicodeStr}`; break; // U+4E00
            case "3": unicodeStr = unicodeToUtf8(glyph.unicode); break; // \xe4\xb8\x80
            case "4": unicodeStr = `\\u${unicodeStr}`; break; // \u4E00
            case "5": unicodeStr = `\\u{${unicodeStr}}`; break; // \u{4E00}
            case "6": unicodeStr = `&#${glyph.unicode};`; break; // &#19968;
            case "7": unicodeStr = `&#x${glyph.unicode.toString(16)};`; break; // &#x4e00;
            default: break;
        }

        valueEl.value = unicodeStr;
        valueEl.disabled = false;
        copyUnicode.disabled = false;
        formatEl.disabled = false;
        caseEl.disabled = false;
    } else {
        valueEl.value = "";
        valueEl.disabled = true;
        copyUnicode.disabled = true;
        formatEl.disabled = true;
        caseEl.disabled = true;
    }
}

function unicodeToUtf8(codePoint) {
    const utf8Bytes = [];
    const bytes = [];

    if (codePoint < 0x80) {
        bytes.push(codePoint);
    } else if (codePoint < 0x800) {
        bytes.push(0xc0 | (codePoint >> 6));
        bytes.push(0x80 | (codePoint & 0x3f));
    } else {
        bytes.push(0xe0 | (codePoint >> 12));
        bytes.push(0x80 | ((codePoint >> 6) & 0x3f));
        bytes.push(0x80 | (codePoint & 0x3f));
    }

    for (let j = 0; j < bytes.length; j++) {
        utf8Bytes.push(bytes[j].toString(16).padStart(2, '0'));
    }

    const utf8Sequence = "\\x" + utf8Bytes.join("\\x");
    return utf8Sequence;
}


