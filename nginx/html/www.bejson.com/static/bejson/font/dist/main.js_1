// 导出所有字形
document.getElementById("export-all-svg").addEventListener("click", e => {
    const font = window.font;

    var zip = new JSZip();
    for (let i = 0; i < font.glyphs.length; i++) {
        var glyph = font.glyphs.get(i);
        var svgDocument = glyphs2SVG(glyph);
        var name = getSVGFileName(glyph);
        zip.file(name, svgDocument);
    }

    zip.generateAsync({ type: 'blob' })
        .then(function (content) {
            const url = URL.createObjectURL(content);
            const link = document.createElement('a');
            link.href = url;
            link.download = fontData.name + "_" + getTimeStr() + '.zip';
            link.click();

            URL.revokeObjectURL(url);
        });
});

// 字形转svg
function glyphs2SVG(glyph) {
    const { x1, y1, x2, y2 } = glyph.getBoundingBox();
    const w = x2 - x1;
    const h = y2 - y1;
    return `<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}" viewBox="${x1} ${y1} ${w} ${h}">${glyph.toSVG()}</svg>`;
}

// 获得svg文件名
function getSVGFileName(glyph) {
    var unicodeStr = "";
    var char = ""
    if (glyph.unicodes.length > 0) {
        unicodeStr = glyph.unicodes.map(formatUnicode).join(', ');
        char = unicode2Char(unicodeStr, 1);
        if (glyph.unicode == 0) {
            unicodeStr = "0000"
            char = ""
        }
    }
    return `${glyph.index + 1}_${unicodeStr}_${char}_${getValueDesc(glyph.name)}.svg`;
}


// 返回 20231024_0953_59
function getTimeStr() {
    var currentDate = new Date();

    var year = currentDate.getFullYear().toString();
    var month = (currentDate.getMonth() + 1).toString().padStart(2, '0');
    var day = currentDate.getDate().toString().padStart(2, '0');

    var hours = currentDate.getHours().toString().padStart(2, '0');
    var minutes = currentDate.getMinutes().toString().padStart(2, '0');
    var seconds = currentDate.getSeconds().toString().padStart(3, '0');

    return year + month + day + '_' + hours + minutes + '_' + seconds;
}

// 导出 iconfont.css
document.getElementById("export-css").addEventListener("click", e => {
    var font = window.font;
    // 读取各字形的css样式名
    var cssNames = [];
    for (let i = 0; i < font.glyphs.length; i++) {
        const glyph = font.glyphs.glyphs[i];
        if (glyph.name == "" || glyph.unicode == undefined) {
            continue;
        }
        var unicodeStr = glyph.unicodes.map(formatUnicode).join(', ').toLowerCase();
        cssNames.push(`.icon-${glyph.name}:before {\n  content: "\\${unicodeStr}";\n}`);
    }

    // 拼接css开头
    var textToSave = `@font-face {
font-family: "iconfont";
src: url('iconfont.ttf?t=${Date.now()}') format('truetype');
}

.iconfont {
font-family: "iconfont" !important;
font-size: 16px;
font-style: normal;
-webkit-font-smoothing: antialiased;
-moz-osx-font-smoothing: grayscale;
}

${cssNames.join("\n\n")}
`
    // 保存
    saveToTxt(textToSave, 'iconfont.css');
});


// 导出 csv
document.getElementById("export-csv").addEventListener("click", e => {
    var arr = [];
    for (let i = 0; i < window.font.glyphs.length; i++) {
        var glyph = window.font.glyphs.get(i);
        arr.push(getCSVRow(glyph));
    }
    var textToSave = `序号,Unicode,字符,名称,字符集
${arr.join("\n")}
备注：由于csv格式限制，“字符”列里面删除了 英文逗号(002C)，英文双引号(0022)吗，CR换行符(000D)，LF换行符(000A)`;
    saveToTxt(textToSave, 'charset.csv');
});

function getCSVRow(glyph) {
    var unicodeStr = "";
    var char = "";
    var gbDesc = "";
    if (glyph.unicodes.length > 0) {
        unicodeStr = glyph.unicodes.map(formatUnicode).join(', ');
        char = unicode2Char(unicodeStr, 2);

        // unicode有多个值时，会用逗号隔开，因此导出csv时需要用双引号括起来
        if (glyph.unicodes.length > 1) {
            unicodeStr = '"' + unicodeStr + '"';
        }
        if (glyph.unicode == 0) {
            unicodeStr = "0000"
            char = ""
        }
        // 标记GB2312字符集
        if (isUnicodeInGB2312("\\u" + unicodeStr)) {
            gbDesc = "GB2312";
            console.log(1);
        }
    }
    var name = getValueDesc(glyph.name);

    return `${glyph.index + 1},${unicodeStr},${char},${name},${gbDesc}`
}

function isUnicodeInGB2312(char) {
    // A1A1－FEFE
    // var pattern = /^[\\u4E00-\\u9FA5]+$/;
    var pattern = /^[\\uA1A1-\\uFEFE]+$/;
    return pattern.test(char);
}

// 保存为文本文件
function saveToTxt(textToSave, downloadName = "1.txt") {
    const blob = new Blob([textToSave], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);

    const link = document.createElement('a');
    link.href = url;
    link.download = downloadName;
    link.click();

    URL.revokeObjectURL(url);
}

var arrowLength = 10,
    arrowAperture = 4;

function drawArrow(ctx, x1, y1, x2, y2) {
    var dx = x2 - x1,
        dy = y2 - y1,
        segmentLength = Math.sqrt(dx * dx + dy * dy),
        unitx = dx / segmentLength,
        unity = dy / segmentLength,
        basex = x2 - arrowLength * unitx,
        basey = y2 - arrowLength * unity,
        normalx = arrowAperture * unity,
        normaly = -arrowAperture * unitx;
    ctx.beginPath();
    ctx.moveTo(x2, y2);
    ctx.lineTo(basex + normalx, basey + normaly);
    ctx.lineTo(basex - normalx, basey - normaly);
    ctx.lineTo(x2, y2);
    ctx.closePath();
    ctx.fill();
}

// 搜索
document.getElementById("search").addEventListener("click", e => {
    var v = document.getElementById("search-char").value;
    if (v == "")
        return;

    var unicode = 0;
    if (v.indexOf("\\u") == 0) {
        // unicode搜索
        unicode = parseInt(v.substr(2), 16);
    }
    else {
        //字符搜索
        // 只支持搜索一个字符
        v = v[0];
        unicode = v.charCodeAt(0).toString(10);
    }

    const font = window.font;
    if (font == undefined)
        return;

    var index = -1;
    for (let i = 0; i < font.glyphs.length; i++) {
        const glyph = font.glyphs.glyphs[i];
        if (glyph.unicode == unicode) {
            index = i;
            break;
        }
    }

    if (index == -1) {
        alert("该字体不包含字符 " + v + " !");
    } else {
        pageSelected = Math.floor(index / cellCount);
        generatePagination()
        displayGlyph(index);
        displayGlyphData(index);
    }
});

function isASCII(str) {
    for (let i = 0; i < str.length; i++) {
        const code = str.charCodeAt(i);
        if (code > 127) {
            return false;
        }
    }
    return true;
}

// 绘制字符的 曲线控制点 和 箭头
document.getElementById("draw-points").addEventListener("change", changeDrawOption);
document.getElementById("draw-arrows").addEventListener("change", changeDrawOption);
function changeDrawOption(e) {
    fontData.drawPoints = document.getElementById("draw-points").checked;
    fontData.drawArrows = document.getElementById("draw-arrows").checked;
    displayGlyph(fontData.glyphIndex);
}

/**
 * This function is Path.prototype.draw with an arrow
 * at the end of each contour.
 */
function drawPathWithArrows(ctx, path) {
    var i, cmd, x1, y1, x2, y2;
    var arrows = [];
    ctx.beginPath();
    for (i = 0; i < path.commands.length; i += 1) {
        cmd = path.commands[i];
        if (cmd.type === 'M') {
            if (x1 !== undefined) {
                arrows.push([ctx, x1, y1, x2, y2]);
            }
            ctx.moveTo(cmd.x, cmd.y);
        } else if (cmd.type === 'L') {
            ctx.lineTo(cmd.x, cmd.y);
            x1 = x2;
            y1 = y2;
        } else if (cmd.type === 'C') {
            ctx.bezierCurveTo(cmd.x1, cmd.y1, cmd.x2, cmd.y2, cmd.x, cmd.y);
            x1 = cmd.x2;
            y1 = cmd.y2;
        } else if (cmd.type === 'Q') {
            ctx.quadraticCurveTo(cmd.x1, cmd.y1, cmd.x, cmd.y);
            x1 = cmd.x1;
            y1 = cmd.y1;
        } else if (cmd.type === 'Z') {
            arrows.push([ctx, x1, y1, x2, y2]);
            ctx.closePath();
        }
        x2 = cmd.x;
        y2 = cmd.y;
    }
    if (path.fill) {
        ctx.fillStyle = path.fill;
        ctx.fill();
    }
    if (path.stroke && fontData.drawArrows) {
        ctx.strokeStyle = path.stroke;
        ctx.lineWidth = path.strokeWidth;
        ctx.stroke();
    }
    ctx.fillStyle = '#000000';

    // 绘制箭头
    if (fontData.drawArrows) {
        arrows.forEach(function (arrow) {
            drawArrow.apply(null, arrow);
        });
    }
}

function displayGlyph(glyphIndex) {
    var canvas = document.getElementById('glyph'),
        ctx = canvas.getContext('2d'),
        width = canvas.width / pixelRatio,
        height = canvas.height / pixelRatio;
    ctx.clearRect(0, 0, width, height);
    if (glyphIndex < 0) return;
    var glyph = window.font.glyphs.get(glyphIndex),
        glyphWidth = glyph.advanceWidth * glyphScale,
        xmin = (width - glyphWidth) / 2,
        xmax = (width + glyphWidth) / 2,
        x0 = xmin,
        markSize = 10;
    window.glyph = glyph;

    ctx.fillStyle = '#606060';
    ctx.fillRect(xmin - markSize + 1, glyphBaseline, markSize, 1);
    ctx.fillRect(xmin, glyphBaseline, 1, markSize);
    ctx.fillRect(xmax, glyphBaseline, markSize, 1);
    ctx.fillRect(xmax, glyphBaseline, 1, markSize);
    ctx.textAlign = 'center';
    ctx.fillText('0', xmin, glyphBaseline + markSize + 10);
    ctx.fillText(glyph.advanceWidth, xmax, glyphBaseline + markSize + 10);

    ctx.fillStyle = '#000000';
    var path = glyph.getPath(x0, glyphBaseline, glyphSize);
    path.fill = '#5E5E5E';
    path.stroke = '#000000';
    path.strokeWidth = 1.5;
    drawPathWithArrows(ctx, path);
    if (fontData.drawPoints) {
        glyph.drawPoints(ctx, x0, glyphBaseline, glyphSize);
    }
}

function renderGlyphItem(canvas, glyphIndex) {
    var cellMarkSize = 8;
    var ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, cellWidth, cellHeight);
    if (glyphIndex >= window.font.numGlyphs) return;

    ctx.fillStyle = '#606060';
    ctx.font = '9px sans-serif';
    ctx.fillText(glyphIndex + 1, 1, cellHeight - 1);
    var glyph = window.font.glyphs.get(glyphIndex),
        glyphWidth = glyph.advanceWidth * fontScale,
        xmin = (cellWidth - glyphWidth) / 2,
        xmax = (cellWidth + glyphWidth) / 2,
        x0 = xmin;

    ctx.fillStyle = '#a0a0a0';
    ctx.fillRect(xmin - cellMarkSize + 1, fontBaseline, cellMarkSize, 1);
    ctx.fillRect(xmin, fontBaseline, 1, cellMarkSize);
    ctx.fillRect(xmax, fontBaseline, cellMarkSize, 1);
    ctx.fillRect(xmax, fontBaseline, 1, cellMarkSize);

    ctx.fillStyle = '#000000';
    glyph.draw(ctx, x0, fontBaseline, fontSize);
}

function displayGlyphPage() {
    var firstGlyph = pageSelected * cellCount;
    for (var i = 0; i < cellCount; i++) {
        renderGlyphItem(document.getElementById('g' + i), firstGlyph + i);
    }
}

function initGlyphDisplay(font) {
    var glyphBgCanvas = document.getElementById('glyph-bg'),
        w = glyphBgCanvas.width / pixelRatio,
        h = glyphBgCanvas.height / pixelRatio,
        glyphW = w - glyphMargin * 2,
        glyphH = h - glyphMargin * 2,
        head = font.tables.head,
        maxHeight = head.yMax - head.yMin,
        ctx = glyphBgCanvas.getContext('2d');

    glyphScale = Math.min(glyphW / (head.xMax - head.xMin), glyphH / maxHeight);
    glyphSize = glyphScale * font.unitsPerEm;
    glyphBaseline = glyphMargin + glyphH * head.yMax / maxHeight;

    function hline(text, yunits) {
        const ypx = glyphBaseline - yunits * glyphScale;
        ctx.fillText(text, 2, ypx + 3);
        ctx.fillRect(80, ypx, w, 1);
    }

    ctx.clearRect(0, 0, w, h);
    ctx.fillStyle = '#a0a0a0'; // #ee5c4f
    hline('基准', 0);
    hline('          yMax', font.tables.head.yMax);
    hline('          yMin', font.tables.head.yMin);
    hline('上升部', font.tables.hhea.ascender);
    hline('下降部', font.tables.hhea.descender);
    hline('排版升部', font.tables.os2.sTypoAscender);
    hline('排版降部', font.tables.os2.sTypoDescender);


    var obj = {};
    if (font.names.hasOwnProperty("windows"))
        obj = font.names["windows"];
    else if (font.names.hasOwnProperty("macintosh"))
        obj = font.names["macintosh"];
    var vName = readZhPossible(obj["postScriptName"])
    var vFamily = readZhPossible(obj["fontSubfamily"])
    var vVersion = readZhPossible(obj["version"])

    fontData.name = getFontZhName(font);

    var fontTile = document.getElementById("font-title");
    var fileName = document.getElementById("file-name");
    var fontSum = document.getElementById("font-summary");

    fontTile.innerText = `${fontData.name}`;
    fileName.innerText = `${fontData.fileName}`;
    fontSum.innerText = `${vName} · ${vFamily} · ${vVersion} · 共 ${font.numGlyphs} 个字符形`;

    showFontInfo(font);
}


// 显示字体信息
function showFontInfo(font) {
    var langDict = {
        postScriptName: "PostScript名称",
        fontFamily: "字体家族名称",
        designer: "设计师",
        manufacturer: "生产商",
        manufacturerURL: "生产商网址",
        copyright: "版权描述",
        license: "授权许可",
        licenseURL: "授权许可网址",
        trademark: "商标",
        fullName: "全名",
        description: "描述",
        fontSubfamily: "样式名称",
        version: "版本",
        uniqueID: "唯一名称",
    }

    var row, td, th;
    var table = document.getElementById('table');
    table.innerHTML = '';

    // name信息
    ['unicode', 'macintosh', 'windows'].forEach(platform => {
        var platformNames = (font.names ? font.names[platform] : null);

        if (!platformNames) return;

        row = table.insertRow();
        th = document.createElement("th");
        th.textContent = platform;
        th.colSpan = 2;
        th.style.textAlign = "center";
        row.appendChild(th);

        var properties = sortKeys(platformNames);
        for (var i = 0; i < properties.length; i++) {
            var property = properties[i];
            var translations = platformNames[property];
            var langs = sortKeys(translations);
            var values = [];
            for (var j = 0; j < langs.length; j++) {
                var lang = langs[j];
                var esclang = escapeHtml(lang);

                values.push('<span class="label label-badge" style="margin-right: 10px">' + esclang + '</span>'
                    + escapeHtml(translations[lang]) + '</span> ');
            }

            // 汉化名称
            var keyName = escapeHtml(property);
            if (langDict.hasOwnProperty(keyName)) {
                keyName = langDict[keyName];
            }

            row = table.insertRow();
            td = row.insertCell(0);
            td.innerText = keyName;
            td.style.whiteSpace = "nowrap";
            td.style.textAlign = "right";
            row.insertCell(1).innerHTML = values.join("<br>");
        }
    });

    var moreDict = {
        ascender: "上升部",
        descender: "下降部",
        defaultWidthX: "字形宽度",
        numGlyphs: "字形数",
        unitsPerEm: 'UPM值',
        outlinesFormat: '轮廓形式',

        numberOfHMetrics: '',
        nominalWidthX: '',
        gsubrsBias: '',
        subrsBias: '',
        isCIDFont: '',
    }

    row = table.insertRow();
    th = document.createElement("th");
    th.textContent = "更多";
    th.colSpan = 2;
    th.style.textAlign = "center";
    row.appendChild(th);

    for (let k in moreDict) {
        if (!font.hasOwnProperty(k))
            continue;

        row = table.insertRow();
        td = row.insertCell(0);
        td.innerText = moreDict[k] != "" ? moreDict[k] : k;
        td.style.whiteSpace = "nowrap";
        td.style.textAlign = "right"
        row.insertCell(1).innerText = font[k];
    }
}

function sortKeys(dict) {
    var keys = [];
    for (var key in dict) {
        keys.push(key);
    }
    keys.sort();
    return keys;
}

function escapeHtml(unsafe) {
    return unsafe
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\u0022/g, '&quot;')
        .replace(/\u0027/g, '&#039;');
}

function getFontZhName(font) {
    var obj = {};
    if (font.names.hasOwnProperty("windows")) {
        obj = font.names["windows"]
    } else if (font.names.hasOwnProperty("macintosh")) {
        obj = font.names["macintosh"]
    } else {
        return "";
    }

    if (obj.fullName.hasOwnProperty("zh")) {
        return obj.fullName.zh
    }
    else if (obj.fullName.hasOwnProperty("en")) {
        return obj.fullName.en
    }

    return ""
}

function readZhPossible(obj) {
    if (obj == undefined)
        return "";

    if (obj.hasOwnProperty("zh"))
        return obj["zh"]

    if (obj.hasOwnProperty("en"))
        return obj["en"]

    var values = Object.values(obj);
    if (values.length > 0)
        return [0];
    else
        return "";
}

function onFontLoaded(font) {
    window.font = font;

    var w = cellWidth - cellMarginLeftRight * 2,
        h = cellHeight - cellMarginTop - cellMarginBottom,
        head = font.tables.head,
        maxHeight = head.yMax - head.yMin;
    fontScale = Math.min(w / (head.xMax - head.xMin), h / maxHeight);
    fontSize = fontScale * font.unitsPerEm;
    fontBaseline = cellMarginTop + h * head.yMax / maxHeight;

    var numPages = Math.ceil(font.numGlyphs / cellCount);
    pageTotal = numPages;
    pageSelected = 0;
    initGlyphDisplay(font);
    generatePagination()
    displayGlyph(0);
    displayGlyphData(0);

    renderText();
}

function renderText() {
    const font = window.font;
    if (!font) return;
    const textToRender = form.textField.value;
    var previewCtx = document.getElementById('preview').getContext('2d');
    var options = {
        kerning: form.kerning.checked,
        hinting: form.hinting.checked,
        features: {
            liga: form.ligatures.checked,
            rlig: form.ligatures.checked
        }
    };
    previewCtx.clearRect(0, 0, 1140, 300);
    const fontSize = +form.fontsize.value;
    font.draw(previewCtx, textToRender, 0, 200, fontSize, options);
    if (form.drawPoints.checked) {
        font.drawPoints(previewCtx, textToRender, 0, 200, fontSize, options);
    }
    if (form.drawMetrics.checked) {
        font.drawMetrics(previewCtx, textToRender, 0, 200, fontSize, options);
    }
}

document.getElementById("page-prev").addEventListener("click", function () {
    if (pageSelected > 0) {
        pageSelected--;
        generatePagination();
    }
});

document.getElementById("page-next").addEventListener("click", function () {
    if (pageSelected < pageTotal - 1) {
        pageSelected++;
        generatePagination();
    }
});

// 生成分页组件
function generatePagination() {
    var ele = document.getElementById("page-input");
    ele.max = pageTotal;
    ele.value = pageSelected + 1;
    document.getElementById("page-total").value = " / " + pageTotal + " 页";
    displayGlyphPage();
}

// 跳转至 输入框事件
document.getElementById("page-input").addEventListener("change", e => {
    var num = parseInt(document.getElementById("page-input").value);
    num = Math.max(1, num);
    if (num > pageTotal)
        num = pageTotal;
    pageSelected = num - 1;
    generatePagination();
});

// 改变单页字形数
document.getElementById("page-select").addEventListener("change", e => {
    cellCount = parseInt(e.target.value);
    pageTotal = Math.ceil(window.font.numGlyphs / cellCount);
    pageSelected = Math.floor(fontData.glyphIndex / cellCount);

    document.getElementById('glyph-list').innerHTML = "";
    prepareGlyphList();

    generatePagination();
});

function getValueDesc(variable) {
    if (typeof variable === 'undefined') {
        return "";
    } else {
        return variable;
    }
}

// 显示toast
function showToast(msg) {
    const toast = document.getElementById("toast");
    toast.textContent = msg;

    toast.classList.add("show");

    setTimeout(() => {
        toast.classList.remove("show");
    }, 3000);
}

